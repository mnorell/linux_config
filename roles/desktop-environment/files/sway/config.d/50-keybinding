bindsym {
    #
    # Basics:
    #
        # Show help
        $super+h exec kitty bat --paging always ~/.config/sway/instructions.md

        # Kill focused window
        $super+Shift+q kill

        # Start launcher
        $super+space exec fuzzel

        # Reload the configuration file
        $super+Shift+c reload

        # Lock screen
        $super+l exec ~/.config/sway/scripts/lock-screen.sh

        # Exit sway (logout of your Wayland session)
        $super+Shift+e exec swaynag -t warning -m 'Really logout?' -B 'Yes, logout' 'swaymsg exit'

        # Toggle screen mirroring
        $super+p exec ~/.config/sway/scripts/screen-mirroring.sh
    #
    # Moving around:
    #
        # Move your focus around
        $super+Left focus left
        $super+Down focus down
        $super+Up focus up
        $super+Right focus right

        # Move the focused window with the same, but add Shift
        $super+Shift+Left move left
        $super+Shift+Down move down
        $super+Shift+Up move up
        $super+Shift+Right move right
    #
    # Workspaces:
    #
        # Switch to workspace
        ##$super+1 workspace number 1
        $super+1 workspace $ws1
        $super+2 workspace $ws2
        $super+3 workspace $ws3
        $super+4 workspace $ws4
        $super+5 workspace $ws5
        $super+6 workspace $ws6
        $super+7 workspace $ws7
        $super+8 workspace $ws8
        $super+9 workspace $ws9
        $super+0 workspace $ws10
        $super+Shift+1 move container to workspace $ws1
        $super+Shift+2 move container to workspace $ws2
        $super+Shift+3 move container to workspace $ws3
        $super+Shift+4 move container to workspace $ws4
        $super+Shift+5 move container to workspace $ws5
        $super+Shift+6 move container to workspace $ws6
        $super+Shift+7 move container to workspace $ws7
        $super+Shift+8 move container to workspace $ws8
        $super+Shift+9 move container to workspace $ws9
        $super+Shift+0 move container to workspace $ws10
    #
    # Move workspace to monitor
        $super+comma move workspace to output right
        $super+period move workspace to output down
    #
    # Rename workspace
        $super+n exec bash ~/.config/sway/scripts/rename_workspace.sh
#
# Layout stuff:
#
    # Toggle split direction
    $super+c splitt

    # Switch the current container between different layout styles
    # $super+s layout stacking
    $super+w layout tabbed
    $super+e layout toggle split

    # Make the current focus fullscreen
    $super+f fullscreen

    # Toggle the current focus between tiling and floating mode
    $super+Shift+f floating toggle

    # Move focus to the parent container
    $super+a focus parent

    # Gaps
    $super+equal gaps inner all plus 5
    $super+minus gaps inner all minus 5
    $super+Shift+equal gaps outer all plus 5
    $super+Shift+minus gaps outer all minus 5
}
#
#
# Resizing containers:
mode "resize" {
    bindsym {
        Left resize shrink width 10px
        Down resize grow height 10px
        Up resize shrink height 10px
        Right resize grow width 10px

        Return mode "default"
        Escape mode "default"
    }
}
bindsym $super+r mode "resize"
