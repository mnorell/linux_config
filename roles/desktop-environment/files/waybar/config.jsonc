{
    "layer": "top",
    "position": "top",
    "height": 35,
    "spacing": 1,
    "modules-left": [
        "sway/workspaces",
        "sway/mode"
    ],
    "modules-center": [
        "sway/window"
    ],
    "modules-right": [
        "idle_inhibitor",   
        "pulseaudio",
        "backlight",
        "cpu",
        "cpu#frequency",
        "custom/cpugovernor",
        "memory",
        // "network",
        "tray",
        "battery",
        "custom/keyboard",
        "clock",
        "custom/power"
    ],
     "sway/workspaces": {
        "disable-scroll": false,
        "all-outputs": false,
        "warp-on-scroll": false,
        "format": "{index}. {windows} {name}",
        "window-format": "<span color='#e0e0e0'>{name}</span>", // icons wont show without this undocumented config
        "format-window-separator": " ",
        "window-rewrite-default": "п„‘", // пҒҷ
        "window-rewrite": {
            
            // Web
            "class<firefox>": "пүЁ", // `пү«`, `пү§`, `пһў`, `пӮ¬`, `п ·`, `п…Җ`
            "class<google-chrome>": "пүЁ",
            "class<brave-browser>": "пүЁ",
            "class<vivaldi-stable>": "пүЁ",
            "class<Chromium>": "пүЁ",

            // Webpages
            // "class<firefox> title<.*github.*>": "п„“"
            "title<.*GitHub.*>": "пӮӣ", // пҲұ
            "title<.*Gmail.*>": "пӮҶ", // пүә пғ  пҒҷ

            // Terminals
            "class<kitty>": "пҶІ", // `пғ»`, `пӢқ`, `пғҲ`, `п…ҙ`
            "class<foot>": "п„ ",
            "class<gnome-terminal>": "п„ ",
            "class<.*Ptyxis>": "п„ ",

            // Code / editors
            "class<jetbrains-idea>": "п„Ұ",
            "class<code>": "пҒ„", // `п„Ұ`, `пӣҢ`, `п„Ў`
            "class<gedit>": "пҒ„",
            "class<.*TextEditor>": "пҒ„",

            // System
            "class<.*Nautilus>": "пҒј",
            "class<thunar>": "пҒј"
        }
     },
    "sway/mode": {
        "format": "<span style=\"italic\">{}</span>"
    },
    "sway/window": {
        "on-click-middle": "swaymsg kill",
        "icon": true
    },
    "idle_inhibitor": {
        "format": "{icon}",
        "format-icons": {
            "activated": "пҒ®",
            "deactivated": "пҒ°"
        }
    },
    "tray": {
        "icon-size": 18,
        "spacing": 10
    },
    "clock": {
        "interval": 1,
        "format-alt": "{:%Y-%m-%d}",
        "tooltip-format": "<tt><small>{calendar}</small></tt>",
        "calendar": {
                    "mode"          : "month",
                    "mode-mon-col"  : 3,
                    "weeks-pos"     : "right",
                    "format": {
                              "months":     "<span color='#cba6f7'><b>{}</b></span>",
                              "days":       "<span color='#cdd6f4'><b>{}</b></span>",
                              "weeks":      "<span color='#94e2d5'>W{}</span>",
                              "weekdays":   "<span color='#f9e2af'><b>{}</b></span>",
                              "today":      "<span color='#f5e0dc'><b><u>{}</u></b></span>"
                              }
                    },
        "actions":  {
                    "on-click-right": "mode"
                    }
    },
    "cpu": {
        "interval": 3,
        // пӢӣпёҸ
        "format": "{usage:2}%",
        "on-click": "gnome-system-monitor"
    },
    "cpu#frequency": {
        "interval": 3,
        "format": "{avg_frequency:1.1f} GHz",
        "tooltip": false
    },
    "memory": {
        "interval": 3,
        "format": "{}% пӮҖ",
        "on-click": "gnome-system-monitor",
        "tooltip-format": "Used: {used:0.1f}/{total:0.1f} GB\nSwap: {swapUsed:0.1f}/{swapTotal:0.1f} GB",
        "states": {
            "critical": 80
        }
    },
    "backlight": {
        // "device": "acpi_video1",
        "format": "{percent}% {icon}",
        "format-icons": ["пғ«"]
    },
    "battery": {
        "states": {
            "warning": 30,
            "critical": 15
        },
        "format": "{time}, {capacity}% {icon}",
        "format-full": "{capacity}% {icon}",
        "format-charging": "{time}, {capacity}% п—§",
        "format-plugged": "{capacity}% пҮҰ",
        // "format-alt": "{time}, {capacity}% {icon}",
        "format-icons": ["пү„", "пүғ", "пүӮ", "пүҒ", "пүҖ"]
    },
    "network": {
        "interval": 60,
        "interface-ethernet": "enp1s*",
        "interface-wifi": "wlan0",
        "format-ethernet": "пһ– eth",
        "format-wifi": "{signalStrength}% пҮ«",
        "tooltip-format-ethernet": "{ifname}: {ipaddr}/{cidr} пһ–",
        "tooltip-format-wifi": "{ifname}: {ipaddr}/{cidr} пҮ«",
        "format-linked": "пһ–(No IP)",
        "format-disconnected": "вҡ  Disconnected",
        // "on-click": "swaymsg exec nmtui connect",
        // "on-click-right": "swaymsg exec nmtui edit"
    },
    "pulseaudio": {
        "scroll-step": 1,
        "format": "{volume}% пҖЁ",
        "format-muted": "пҖҰ",
        "on-click": "pactl set-sink-mute @DEFAULT_SINK@ toggle",
        "on-click-middle": "pavucontrol"
    },
    "custom/power": {
        "format" : " вҸ» ",
		"tooltip": false,
		"menu": "on-click",
		"menu-file": "/home/markus/.config/waybar/power_menu.xml",
		"menu-actions": {
            "reload": "swaymsg reload",
            "logout":   "swaynag -t warning -m 'Really logout'   -B 'Yes, logout'   'swaymsg exit'",
			"shutdown": "swaynag -t warning -m 'Really shutdown' -B 'Yes, shutdown' 'shutdown'",
			"reboot":   "swaynag -t warning -m 'Really reboot'   -B 'Yes, reboot'   'reboot'"
		}
    },
    //Workaround, my keyboard layouts are not properly configured, can't use sway/language.
    "custom/keyboard": {
        "format": "{} п„ң",
        "tooltip": false,
        "interval": 1,
        "exec": "~/.config/waybar/scripts/get_layout.sh",
        "on-click": "swaymsg input type:keyboard xkb_switch_layout next"
    },
    "custom/cpugovernor": {
        "format": "{}",
        "interval": 1,
        "return-type": "json",
        "exec": "sh ~/.config/waybar/scripts/get_cpugovernor.sh",
        "on-click": "sh ~/.config/waybar/scripts/toggle_cpugovernor.sh",
        "tooltip": true
    }
}
